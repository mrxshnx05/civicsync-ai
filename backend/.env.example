# ============================================
# CIVICSYNC AI - Environment Configuration
# ============================================

# --- OPENROUTER API ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash:free

# --- AWS IAM Credentials ---
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# --- Amazon S3 ---
AWS_S3_BUCKET=civicsync-images-your-unique-name

# --- Amazon Bedrock ---
BEDROCK_MODEL_ID=anthropic.claude-v2

# --- DynamoDB ---
DYNAMODB_TABLE=civicsync-reports

# --- MongoDB Atlas ---
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=YourCluster
MONGODB_DATABASE=civicsync

# --- Application Settings ---
ENVIRONMENT=development
DEBUG=True
PORT=8000

# --- Demo Mode ---
DEMO_MODE=True